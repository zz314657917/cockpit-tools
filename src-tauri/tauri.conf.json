{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cockpit Tools",
  "version": "0.21.3",
  "identifier": "com.jlcodes.cockpit-tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Cockpit Tools",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "resizable": true
      },
      {
        "label": "floating-card",
        "title": "Cockpit Tools",
        "create": false,
        "width": 250,
        "height": 290,
        "minWidth": 250,
        "minHeight": 290,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/assets/icons/antigravity-menu.png": "native-menu-icons/antigravity-menu.png",
      "../src/assets/icons/codebuddy.png": "native-menu-icons/codebuddy.png",
      "../src/assets/icons/codex.svg": "native-menu-icons/codex.svg",
      "../src/assets/icons/cursor-menu.png": "native-menu-icons/cursor-menu.png",
      "../src/assets/icons/gemini-menu.png": "native-menu-icons/gemini-menu.png",
      "../src/assets/icons/github-copilot.svg": "native-menu-icons/github-copilot.svg",
      "../src/assets/icons/kiro-menu.png": "native-menu-icons/kiro-menu.png",
      "../src/assets/icons/qoder.png": "native-menu-icons/qoder.png",
      "../src/assets/icons/trae.png": "native-menu-icons/trae.png",
      "../src/assets/icons/windsurf.svg": "native-menu-icons/windsurf.svg",
      "../src/assets/icons/workbuddy.png": "native-menu-icons/workbuddy.png",
      "../src/assets/icons/zed.png": "native-menu-icons/zed.png"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "cockpit-tools",
          "cockpittools"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxRkU1RTdBRDdCRUUzM0QKUldROTQ3N1hlbDcrd1ZVQ2E3b1ZoVUdXL3BWQmpjdzNnWllNUW1LNHVwcE9wdGI1Q1UxQmdnQ0oK",
      "endpoints": [
        "https://github.com/jlcodes99/cockpit-tools/releases/latest/download/latest.json"
      ]
    }
  }
}
